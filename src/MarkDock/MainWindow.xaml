<Window x:Class="MarkDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarkDock"
        Title="MarkDock" Height="450" Width="600"
        ContentRendered="MainWindow_Loaded"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <local:BoolToStarConverter x:Key="BoolToStarConverter"/>
        <local:DeadLinkStatusConverter x:Key="DeadLinkStatusConverter"/>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="WindowForegroundBrush" Color="#202020"/>
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="GroupHeaderBackgroundBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="GroupHeaderForegroundBrush" Color="#202020"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="SearchBox"
                     Height="30"
                     Padding="0,0,26,0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource WindowForegroundBrush}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     TextChanged="SearchBox_TextChanged"/>
            <TextBlock Text="Suchen..."
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="Gray"
                       FontSize="14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <Button Content="✕"
                    Click="ClearSearchButton_Click"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="22"
                    Height="22"
                    Margin="0,0,4,0"
                    FontSize="11"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="Gray">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="LauncherButton"
                    Content="🚀 Launcher"
                    Margin="0,0,10,0"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    ToolTip="Auch per Strg+Leertaste erreichbar"
                    Click="LauncherButton_Click"/>
            <Button x:Name="ChangeHotkeyButton"
                    Content="⚙"
                    Margin="0,0,10,0"
                    Width="30"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    ToolTip="Launcher-Tastenkombination ändern"
                    Click="ChangeHotkeyButton_Click"/>
            <Button x:Name="ImportHtmlButton"
                    Content="HTML importieren..."
                    Margin="0,0,10,0"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    Click="ImportHtmlButton_Click"/>
            <Button x:Name="ExportButton"
                    Content="Exportieren..."
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    Click="ExportButton_Click"/>
            <ComboBox x:Name="BrowserFilterComboBox"
                      Width="150"
                      Margin="10,0,0,0"
                      Height="30"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource WindowForegroundBrush}"
                      SelectionChanged="BrowserFilterComboBox_SelectionChanged"/>
            <Button x:Name="CheckLinksButton"
                    Content="Links prüfen"
                    Margin="10,0,0,0"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    Click="CheckLinksButton_Click"/>
            <Button x:Name="DeleteDeadLinksButton"
                    Content="Tote Links entfernen"
                    Margin="10,0,0,0"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    Click="DeleteDeadLinksButton_Click"/>
            <Button x:Name="BackupButton"
                    Content="Backup erstellen"
                    Margin="10,0,0,0"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    Click="BackupButton_Click"/>
            <Button x:Name="RestoreButton"
                    Content="Backup wiederherstellen"
                    Margin="10,0,0,0"
                    Height="30"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource WindowForegroundBrush}"
                    Click="RestoreButton_Click"/>
            <Button x:Name="DeleteAllButton"
                    Content="🗑 Alles löschen"
                    Margin="60,0,0,0"
                    Height="30"
                    Background="#C0392B"
                    Foreground="White"
                    Click="DeleteAllButton_Click"/>
            <Button x:Name="ThemeToggleButton"
                    Content="🌙"
                    ToolTip="Dunkles/Helles Design umschalten"
                    Width="40"
                    Height="30"
                    Margin="10,0,0,0"
                    FontSize="16"
                    Click="ThemeToggleButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ThemeButtonBorder" Background="#4A90D9" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThemeButtonBorder" Property="Background" Value="#3A7BC8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
        <ListView x:Name="BookmarksListView"
                  Grid.Row="2"
                  SelectionMode="Extended"
                  Background="{DynamicResource ControlBackgroundBrush}"
                  Foreground="{DynamicResource WindowForegroundBrush}"
                  MouseDoubleClick="BookmarksListView_MouseDoubleClick"
                  PreviewMouseRightButtonDown="BookmarksListView_PreviewMouseRightButtonDown"
                  ContextMenuOpening="BookmarksListView_ContextMenuOpening">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Bearbeiten..." Click="EditBookmarkMenuItem_Click"/>
                    <MenuItem Header="In Ordner verschieben..." Click="MoveToFolderMenuItem_Click"/>
                    <MenuItem Header="Als OK markieren" Click="MarkAsOkMenuItem_Click"/>
                    <MenuItem Header="Als tot markieren" Click="MarkAsDeadMenuItem_Click"/>
                    <MenuItem Header="Löschen" Click="DeleteBookmarkMenuItem_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Background="{DynamicResource GroupHeaderBackgroundBrush}"
                                       Foreground="{DynamicResource GroupHeaderForegroundBrush}"
                                       Padding="4,2"
                                       Margin="0,4,0,0">
                                <TextBlock.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Ordner umbenennen..." Click="RenameFolderMenuItem_Click"/>
                                        <MenuItem Header="Ordner auflösen (Bookmarks bleiben erhalten)" Click="DeleteFolderMenuItem_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="24">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding FaviconUrl}" Width="16" Height="16"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="★" Width="36">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                        Click="ToggleFavorite_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="18"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Quelle" DisplayMemberBinding="{Binding Browser}" Width="100"/>
                    <GridViewColumn Width="150">
                        <GridViewColumn.Header>
                            <Button Content="Ordner" Click="FolderColumnHeader_Click" Background="Transparent" BorderThickness="0" Padding="0"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Folder}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="70">
                        <GridViewColumn.Header>
                            <Button Content="Status" Click="StatusColumnHeader_Click" Background="Transparent" BorderThickness="0" Padding="0"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsDead, Converter={StaticResource DeadLinkStatusConverter}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="250">
                        <GridViewColumn.Header>
                            <Button Content="Titel" Click="TitleColumnHeader_Click" Background="Transparent" BorderThickness="0" Padding="0"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="URL"   DisplayMemberBinding="{Binding Url}"  Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,5">
            <TextBlock x:Name="StatusText" Text="0 Bookmarks" Foreground="{DynamicResource WindowForegroundBrush}"/>
        </StackPanel>
    </Grid>
</Window>
